-- LOGIC KÉO (NGÓN ĐẦU TIÊN + KHÓA CAMERA)
-- ==========================================
local dragging = false
local dragStart, startPos, activeTouch

toggle.InputBegan:Connect(function(input)
    if not dragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true
        toggle.Modal = true 
        activeTouch = input
        dragStart = input.Position
        startPos = main.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == activeTouch then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == activeTouch then
        dragging = false
        toggle.Modal = false
        activeTouch = nil
    end
end)

