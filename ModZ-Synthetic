-- HÀM XỬ LÝ
-- ==========================================
local function tween(o, t, p)
    TweenService:Create(o, TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), p):Play()
end

local function fuzzy(a, b)
    a, b = a:lower(), b:lower()
    local j = 1
    for i = 1, #a do
        if a:sub(i, i) == b:sub(j, j) then j += 1 end
        if j > #b then return true end
    end
    return false
end

local collapsed = false

local function render(txt)
    for _, c in pairs(list:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end

    local count = 0
    for _, v in pairs(Scripts) do
        local show = false
        if txt == "" then show = true
        else
            for _, n in pairs(v.Name) do
                if fuzzy(n, txt) then show = true break end
            end
        end

        if show then
            count += 1
            local b = Instance.new("TextButton", list)
            b.Size = UDim2.new(1, -5, 0, 26) 
            b.Text = "> " .. v.Name[1]
            b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            b.BackgroundTransparency = 0.2
            b.TextColor3 = Color3.new(1, 1, 1)
            b.Font = Enum.Font.Arcade
            b.TextSize = 15
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.BorderSizePixel = 0

            b.MouseButton1Click:Connect(function()
                box.Text = "" 
                collapsed = true
                toggle.Text = "+"
                render("")
                pcall(function() loadstring(game:HttpGet(v.url))() end)
            end)
        end
    end

    local maxHeight = math.min(count, 5) * 28
    local targetSize = (collapsed or count == 0) and 0 or maxHeight
    tween(list, 0.2, {Size = UDim2.new(1, 0, 0, targetSize)})
end

box:GetPropertyChangedSignal("Text"):Connect(function()
    if collapsed and box.Text ~= "" then 
        collapsed = false 
        toggle.Text = "-"
    end
    render(box.Text)
end)

toggle.MouseButton1Click:Connect(function()
    collapsed = not collapsed
    toggle.Text = collapsed and "+" or "-"
    render(box.Text)
end)

render("")
